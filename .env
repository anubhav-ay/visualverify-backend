# ════════════════════════════════════════════════════════
# Misinformation Detection System — Environment Variables
# Copy this file to .env and fill in your API keys.
# ALL keys are optional — the system uses local AI fallbacks
# when any key is missing.
# ════════════════════════════════════════════════════════

# ── Stage 2: Bing Visual Search (optional) ──────────────
# Sign up free: https://www.microsoft.com/en-us/bing/apis/bing-visual-search-api
BING_VISUAL_SEARCH_KEY=

# ── Stage 3: Google Fact Check API (optional) ────────────
# Obtain free key: https://developers.google.com/fact-check/tools/api/reference/rest
GOOGLE_FACT_CHECK_KEY=

# ── Stage 4: NewsAPI (optional) ──────────────────────────
# Free tier: https://newsapi.org/register
NEWS_API_KEY=

# ── Stage 4: MediaStack Fallback (optional) ──────────────
# Free tier: https://mediastack.com/signup/free
MEDIASTACK_API_KEY=
